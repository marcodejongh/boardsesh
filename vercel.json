{
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "if [ \"$VERCEL_ENV\" != \"preview\" ]; then bun run db:migrate; fi && bun run --filter=@boardsesh/web build",
  "outputDirectory": "packages/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/internal/shared-sync/tension",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/internal/shared-sync/kilter",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/internal/user-sync-cron",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/internal/migrate-users-cron",
      "schedule": "0 3 * * *"
    }
  ]
}
