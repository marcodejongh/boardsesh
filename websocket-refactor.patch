+   */
+  triggerResync(): void {
+    if (this.disposed || !this.client) return;
+    if (this.stateMachine.state !== 'CONNECTED' && this.stateMachine.state !== 'RECONNECTING') return;
+
+    if (DEBUG) console.log('[SessionConnection] Manual resync triggered');
+    this.handleReconnect();
+  }
